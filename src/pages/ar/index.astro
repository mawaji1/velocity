---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Stats from '../../components/Stats.astro';
import Selection from '../../components/Selection.astro';
import Tracks from '../../components/Tracks.astro';
import Journey from '../../components/Journey.astro';
import Benefits from '../../components/Benefits.astro';
import Prizes from '../../components/Prizes.astro';
import Audience from '../../components/Audience.astro';
import Eligibility from '../../components/Eligibility.astro';
import LeaveWith from '../../components/LeaveWith.astro';
import Technologies from '../../components/Technologies.astro';
import AccelPipeline from '../../components/AccelPipeline.astro';
import FAQ from '../../components/FAQ.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import Footer from '../../components/Footer.astro';
import { content } from '../../i18n/content';

const locale = 'ar' as const;
const t = content[locale];
---
<Base locale={locale}>
  <Header slot="header" t={t} locale={locale} />
  <Hero t={t} />
  <Stats t={t} />
  <Selection t={t} />
  <Prizes t={t} />
  <Journey t={t} />
  <Tracks t={t} />
  <Audience t={t} />
  <Eligibility t={t} />
  <LeaveWith t={t} />
  <Benefits t={t} />
  <Technologies t={t} />
  <AccelPipeline t={t} />
  <FinalCTA t={t} />
  <FAQ t={t} />
  <Footer slot="footer" t={t} locale={locale} />
</Base>
