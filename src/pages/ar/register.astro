---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RegistrationForm from '../../components/RegistrationForm.astro';
import { content } from '../../i18n/content';
import { registerContent } from '../../i18n/register-schema';

const locale = 'ar' as const;
const t = content[locale];
const copy = registerContent[locale];
---
<Base locale={locale}>
  <Header slot="header" t={t} locale={locale} />
  <RegistrationForm locale={locale} />
  <Footer slot="footer" t={t} locale={locale} />
  <Fragment slot="meta">
    <title>{copy.meta.title}</title>
    <meta name="description" content={copy.meta.description} />
  </Fragment>
</Base>
