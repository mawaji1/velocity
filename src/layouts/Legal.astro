---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Content, Locale } from '../i18n/content';

type Section = {
  title: string;
  body?: readonly string[];
  list?: readonly string[];
  footer?: string;
  subtitle?: string;
  contact?: boolean;
  extra?: {
    title: string;
    body?: readonly string[];
    list?: readonly string[];
  };
};

interface Props {
  t: Content;
  locale: Locale;
  title: string;
  program?: string;
  intro?: string;
  sections: readonly Section[];
}

const { t, locale, title, program, intro, sections } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base locale={locale}>
  <Header slot="header" t={t} locale={locale} />

  <article class="relative pb-24 pt-14 md:pb-32 md:pt-20">
    <div class="mx-auto max-w-[860px] px-5 sm:px-8">
      <a
        href={`${base}/${locale}/`}
        class="mb-6 inline-flex items-center gap-2 text-sm text-white/60 transition hover:text-white"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4 rtl:rotate-180" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"></path>
        </svg>
        {t.legal.backToHome}
      </a>

      <h1 class="text-3xl font-extrabold text-white md:text-5xl">{title}</h1>
      {program && <p class="mt-3 text-sm font-semibold text-[color:var(--color-red-primary)]">{program}</p>}
      {intro && <p class="mt-6 text-[15px] leading-8 text-white/75">{intro}</p>}

      <div class="mt-10 space-y-10">
        {sections.map((s) => (
          <section>
            <h2 class="text-xl font-bold text-white md:text-2xl">{s.title}</h2>
            {s.body && s.body.map((p) => <p class="mt-3 text-[14.5px] leading-8 text-white/75">{p}</p>)}
            {s.list && (
              <ul class="mt-4 space-y-2.5 text-[14.5px] leading-7 text-white/80">
                {s.list.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-2.5 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--color-red-primary)]"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
            {s.footer && <p class="mt-4 text-[14.5px] leading-8 text-white/70">{s.footer}</p>}

            {s.extra && (
              <div class="mt-6 rounded-2xl border border-white/10 bg-white/[0.03] p-5 md:p-6">
                <h3 class="text-base font-semibold text-white">{s.extra.title}</h3>
                {s.extra.body && s.extra.body.map((p) => <p class="mt-3 text-[14px] leading-7 text-white/75">{p}</p>)}
                {s.extra.list && (
                  <ul class="mt-3 space-y-2 text-[14px] leading-7 text-white/80">
                    {s.extra.list.map((item) => (
                      <li class="flex items-start gap-3">
                        <span class="mt-2.5 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--color-red-primary)]"></span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            )}

            {s.contact && (
              <div class="mt-4 space-y-2 rounded-2xl border border-white/10 bg-white/[0.03] p-5 text-[14.5px] md:p-6">
                <div>
                  <span class="font-semibold text-white">Email: </span>
                  <a href={`mailto:${t.legal.contactEmail}`} class="text-[color:var(--color-red-primary)] hover:underline">{t.legal.contactEmail}</a>
                </div>
                <div>
                  <span class="font-semibold text-white">Web: </span>
                  <a href={t.legal.contactWebsite.href} target="_blank" rel="noopener" class="text-[color:var(--color-red-primary)] hover:underline">
                    {t.legal.contactWebsite.label}
                  </a>
                </div>
              </div>
            )}
          </section>
        ))}
      </div>
    </div>
  </article>

  <Footer slot="footer" t={t} locale={locale} />
</Base>
