---
import type { Content, Locale } from '../i18n/content';
interface Props { t: Content; locale: Locale }
const { t, locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const socialIcons: Record<string, string> = {
  x: 'M4 4l16 16 M20 4L4 20',
  linkedin: 'M4 4h4v16H4z M4 4a2 2 0 114 0 2 2 0 01-4 0z M10 9h4v2 M14 9c3 0 6 2 6 6v5h-4v-5a2 2 0 00-4 0v5h-4v-11h4v2',
};
---
<footer class="border-t border-white/5 bg-[color:var(--color-black-primary)]">
  <div class="mx-auto max-w-[1240px] px-5 py-14 sm:px-8 md:py-16">
    <div class="flex flex-col items-start gap-10 md:flex-row md:items-center md:justify-between md:gap-8">
      <a href={`${base}/${locale}/`} class="flex items-center gap-3">
        <img src={`${base}/seulogo.svg`} alt="SEU" class="h-10 w-10" />
        <span class="text-sm font-semibold tracking-wide text-white/90">{t.nav.brand}</span>
      </a>

      <nav class="flex flex-wrap items-center gap-x-8 gap-y-3 text-sm text-white/75">
        {t.footer.links.map((l) => (
          <a href={l.href} target="_blank" rel="noopener" class="transition hover:text-white">{l.label}</a>
        ))}
      </nav>

      <div class="flex items-center gap-4">
        <span class="text-xs text-white/50 md:text-sm">{t.footer.tagline}</span>
        <div class="flex items-center gap-3">
          {t.footer.socials.map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              target="_blank"
              rel="noopener"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-white/70 transition hover:border-white/30 hover:text-white"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={socialIcons[s.icon]}></path>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-4 border-t border-white/5 pt-6 text-xs text-white/50 md:flex-row md:items-center md:justify-between">
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
        {t.footer.legal.map((l) => (
          <a href={l.href} class="transition hover:text-white">{l.label}</a>
        ))}
      </div>
      <div class="text-white/45">{t.footer.rights}</div>
    </div>
  </div>
</footer>
