---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const lw = t.leaveWith;
const iconPaths: Record<string, string> = {
  rocket: 'M4 20s2-4 6-6l6-6s3-3 6-2c1 3-2 6-2 6l-6 6c-2 4-6 6-6 6z M9 11l4 4 M14 6l4 4',
  target: 'M12 22a10 10 0 100-20 10 10 0 000 20z M12 18a6 6 0 100-12 6 6 0 000 12z M12 14a2 2 0 100-4 2 2 0 000 4z',
  media: 'M23 7l-7 5 7 5V7z M14 5H3a2 2 0 00-2 2v10a2 2 0 002 2h11a2 2 0 002-2V7a2 2 0 00-2-2z',
  mentor: 'M4 19h4l10-10-4-4L4 15v4z M14 7l3 3',
};
---
<section id="leave-with" class="relative border-y border-white/5 bg-white/[0.02] py-20 md:py-28">
  <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mb-12 text-center md:mb-14">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">{lw.title}</h2>
      <p class="mt-3 text-[15px] text-white/60">{lw.subtitle}</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 md:gap-5 lg:grid-cols-3">
      {lw.items.map((it) => (
        <div class="flex items-start gap-4 rounded-2xl border border-white/10 bg-white/[0.03] p-5 transition hover:border-white/20 hover:bg-white/[0.05] md:p-6">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[color:var(--color-red-primary)]/15 text-[color:var(--color-red-primary)] ring-1 ring-inset ring-[color:var(--color-red-primary)]/30">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[it.icon] ?? iconPaths.rocket}></path>
            </svg>
          </div>
          <div>
            <h3 class="text-[15px] font-bold text-white md:text-base">{it.title}</h3>
            <p class="mt-1.5 text-[13px] leading-6 text-white/65 md:text-sm">{it.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
