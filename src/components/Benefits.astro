---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const iconPaths: Record<string, string> = {
  certificate: 'M12 15a4 4 0 100-8 4 4 0 000 8z M9.5 14.5L8 22l4-2 4 2-1.5-7.5',
  rocket: 'M4 20s2-4 6-6l6-6s3-3 6-2c1 3-2 6-2 6l-6 6c-2 4-6 6-6 6z M9 11l4 4 M14 6l4 4',
  partners: 'M3 11a2 2 0 012-2h3v6H5a2 2 0 01-2-2v-2z M16 9h3a2 2 0 012 2v2a2 2 0 01-2 2h-3V9z M9 9V7a3 3 0 016 0v2',
  mentor: 'M4 19h4l10-10-4-4L4 15v4z M14 7l3 3',
  trophy: 'M8 21h8 M12 17v4 M6 3h12v4a6 6 0 01-12 0V3z M6 5H3v2a3 3 0 003 3 M18 5h3v2a3 3 0 01-3 3',
  support: 'M12 22s8-4.5 8-12V4l-8-2-8 2v6c0 7.5 8 12 8 12z M9 12l2 2 4-4',
};
---
<section id="benefits" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mb-12 text-center md:mb-16">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">{t.benefits.title}</h2>
      <p class="mt-3 text-[15px] text-white/60">{t.benefits.subtitle}</p>
    </div>

    <div class="flex flex-wrap justify-center gap-5 md:gap-6">
      {t.benefits.items.map((b) => (
        <div class="relative flex w-full flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] p-7 text-center transition hover:border-white/20 hover:bg-white/[0.05] md:w-[calc(50%-0.75rem)] md:p-8">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-[color:var(--color-red-primary)] text-white shadow-[0_10px_30px_-10px_rgba(223,51,38,0.7)]">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[b.icon] ?? iconPaths.trophy}></path>
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold text-white md:text-xl">{b.title}</h3>
          <p class="mt-3 text-sm leading-7 text-white/65 md:text-[15px]">{b.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
