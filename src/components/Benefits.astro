---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const iconPaths: Record<string, string> = {
  certificate: 'M12 15a4 4 0 100-8 4 4 0 000 8z M9.5 14.5L8 22l4-2 4 2-1.5-7.5',
  rocket: 'M4 20s2-4 6-6l6-6s3-3 6-2c1 3-2 6-2 6l-6 6c-2 4-6 6-6 6z M9 11l4 4 M14 6l4 4',
  partners: 'M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2 M9 11a4 4 0 100-8 4 4 0 000 8z M22 21v-2a4 4 0 00-3-3.87 M16 3.13A4 4 0 0119 7a4 4 0 01-3 3.87',
  mentor: 'M4 19h4l10-10-4-4L4 15v4z M14 7l3 3',
  trophy: 'M8 21h8 M12 17v4 M6 3h12v4a6 6 0 01-12 0V3z M6 5H3v2a3 3 0 003 3 M18 5h3v2a3 3 0 01-3 3',
  support: 'M12 22s8-4.5 8-12V4l-8-2-8 2v6c0 7.5 8 12 8 12z M9 12l2 2 4-4',
};

const arDigits = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
const formatNumber = (n: number) => {
  const s = String(n).padStart(2, '0');
  return t.lang === 'ar' ? s.replace(/\d/g, (d) => arDigits[+d]) : s;
};
---
<section id="benefits" class="benefits-section relative overflow-hidden py-16 md:py-24">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="relative mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="grid gap-10 md:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] md:gap-14 lg:gap-20">
      {/* Heading column */}
      <div class="benefits-head text-start">
        <div class="inline-flex items-center gap-2 text-[10.5px] font-semibold uppercase tracking-[0.3em] text-[color:var(--color-red-primary)]">
          <span class="h-1.5 w-6 rounded-full bg-[color:var(--color-red-primary)]"></span>
          {t.lang === 'ar' ? 'المزايا' : 'Benefits'}
        </div>
        <h2 class="mt-4 text-3xl font-extrabold leading-[1.1] tracking-tight text-white md:text-[44px] md:leading-[1.05]">{t.benefits.title}</h2>
        <div class="mt-5 h-[3px] w-20 rounded-full bg-gradient-to-r from-[color:var(--color-red-primary)] via-[color:var(--color-red-primary)]/60 to-transparent"></div>
      </div>

      {/* List column */}
      <ul class="benefits-list relative" data-benefits>
        {t.benefits.items.map((b, i) => (
          <li
            class="benefit-row group relative flex items-start gap-5 py-6 transition-colors duration-300 first:pt-0 last:pb-0 md:gap-7 md:py-7"
            style={`--reveal-delay: ${i * 100}ms;`}
          >
            {/* Number rail on the start side */}
            <div class="flex shrink-0 flex-col items-center gap-3 pt-1 md:gap-4">
              <span class="text-[12px] font-bold tabular-nums text-[color:var(--color-red-primary)] md:text-[13px]">{formatNumber(i + 1)}</span>
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-[color:var(--color-red-primary)]/12 ring-1 ring-inset ring-[color:var(--color-red-primary)]/30 transition-colors duration-300 group-hover:bg-[color:var(--color-red-primary)]/22 group-hover:ring-[color:var(--color-red-primary)]/55 md:h-12 md:w-12">
                <svg viewBox="0 0 24 24" class="h-5 w-5 text-[color:var(--color-red-primary)] md:h-[22px] md:w-[22px]" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d={iconPaths[b.icon] ?? iconPaths.trophy}></path>
                </svg>
              </div>
            </div>

            <div class="min-w-0 flex-1">
              <h3 class="text-[17px] font-bold leading-snug text-white md:text-[19px]">{b.title}</h3>
              <p class="mt-2 text-[13.5px] leading-7 text-white/65 md:text-[14.5px] md:leading-7">{b.desc}</p>
            </div>

            {/* Hairline divider between rows (skip last) */}
            {i < t.benefits.items.length - 1 && (
              <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-white/0 via-white/10 to-white/0 md:via-white/12"></div>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>('[data-benefits]');
  const head = document.querySelector<HTMLElement>('.benefits-head');
  if (root) {
    const rows = Array.from(root.querySelectorAll<HTMLElement>('.benefit-row'));
    const targets = head ? [head, ...rows] : rows;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!('IntersectionObserver' in window) || reduced) {
      targets.forEach((t) => t.classList.add('revealed'));
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('revealed');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.2 });
      targets.forEach((t) => io.observe(t));
    }
  }
</script>

<style>
  .benefits-section {
    background: linear-gradient(180deg, var(--color-black-primary) 0%, rgba(255, 255, 255, 0.012) 50%, var(--color-black-primary) 100%);
  }
  .benefits-head,
  .benefit-row {
    opacity: 0;
    transform: translateY(20px);
  }
  .benefits-head.revealed,
  .benefit-row.revealed {
    animation: benefit-in 720ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }
  @keyframes benefit-in {
    to { opacity: 1; transform: translateY(0); }
  }
  /* Subtle row hover — no full card lift, just a lateral wash */
  .benefit-row::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 16px;
    background: linear-gradient(90deg, rgba(223, 51, 38, 0.05), transparent 60%);
    opacity: 0;
    transition: opacity 300ms ease;
    pointer-events: none;
  }
  html[dir="rtl"] .benefit-row::before {
    background: linear-gradient(-90deg, rgba(223, 51, 38, 0.05), transparent 60%);
  }
  .benefit-row:hover::before { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    .benefits-head,
    .benefit-row {
      opacity: 1;
      transform: none;
      animation: none !important;
    }
    .benefit-row::before { display: none; }
  }
</style>
