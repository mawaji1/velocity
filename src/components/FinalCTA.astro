---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
---
<section id="register" class="relative overflow-hidden py-24 md:py-32">
  <div class="pointer-events-none absolute left-1/2 top-1/2 h-[620px] w-[620px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(closest-side,rgba(223,51,38,0.55),transparent_70%)] blur-[20px]"></div>

  <div class="relative mx-auto max-w-[900px] px-5 text-center sm:px-8">
    <h2 class="text-3xl font-extrabold leading-tight text-white md:text-5xl">
      {t.finalCta.title}
    </h2>
    <p class="mx-auto mt-5 max-w-2xl text-[15px] leading-8 text-white/75 md:text-base">
      {t.finalCta.lead}
    </p>
    <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
      <a
        href={t.finalCta.ctaPrimary.href}
        class="rounded-full bg-[color:var(--color-red-primary)] px-6 py-3 text-sm font-semibold text-white shadow-[0_12px_40px_-10px_rgba(223,51,38,0.6)] transition hover:bg-[color:var(--color-red-primary-hover)] md:text-[15px]"
      >
        {t.finalCta.ctaPrimary.label}
      </a>
      <a
        href={t.finalCta.ctaSecondary.href}
        class="rounded-full border border-white/20 bg-white/5 px-6 py-3 text-sm font-semibold text-white/90 transition hover:border-white/40 hover:bg-white/10 md:text-[15px]"
      >
        {t.finalCta.ctaSecondary.label}
      </a>
    </div>
  </div>
</section>
