---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const sel = t.selection;
---
<section id="selection" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mb-12 text-center md:mb-14">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">{sel.title}</h2>
      <p class="mt-3 text-[15px] text-white/60">{sel.subtitle}</p>
    </div>

    <ol class="relative grid gap-4 sm:grid-cols-2 md:grid-cols-4 md:gap-5">
      <div class="pointer-events-none absolute top-[42px] start-0 end-0 hidden h-px bg-gradient-to-r from-transparent via-[color:var(--color-red-primary)]/40 to-transparent md:block"></div>

      {sel.steps.map((step, idx) => (
        <li class="relative flex flex-col items-center rounded-2xl border border-white/10 bg-white/[0.03] p-5 text-center transition hover:border-white/20 md:p-6">
          <div class="relative flex h-14 w-14 items-center justify-center rounded-2xl bg-[color:var(--color-red-primary)] text-base font-bold text-white shadow-[0_10px_30px_-10px_rgba(223,51,38,0.7)]">
            {step.n}
          </div>
          <h3 class="mt-4 text-[15px] font-bold text-white md:text-base">{step.title}</h3>
          <p class="mt-2 text-[13px] leading-6 text-white/65">{step.desc}</p>
          {idx < sel.steps.length - 1 && (
            <div class="pointer-events-none absolute end-[-14px] top-1/2 hidden -translate-y-1/2 md:block rtl:rotate-180">
              <svg viewBox="0 0 24 24" class="h-4 w-4 text-[color:var(--color-red-primary)]/70" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 6l6 6-6 6"></path>
              </svg>
            </div>
          )}
        </li>
      ))}
    </ol>

    <p class="mx-auto mt-10 max-w-3xl rounded-2xl border border-amber-300/25 bg-amber-300/6 px-5 py-4 text-center text-[13.5px] leading-7 text-amber-100/95 md:text-[14px]">
      {sel.footer}
    </p>
  </div>
</section>
