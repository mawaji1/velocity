---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
---
<section id="why" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-[1100px] px-5 sm:px-8">
    <div class="max-w-3xl">
      <h2 class="text-3xl font-extrabold text-white md:text-5xl">{t.why.title}</h2>
      <div class="mt-6 text-[color:var(--color-red-primary)] text-base font-bold tracking-wide md:text-lg">{t.why.programName}</div>
      <div class="mt-5 space-y-5 text-[15px] leading-8 text-white/75 md:text-[17px] md:leading-9">
        {t.why.paragraphs.map((p) => (
          <p>{p}</p>
        ))}
      </div>
    </div>
  </div>
</section>
