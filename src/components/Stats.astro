---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
---
<section id="why" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-[1100px] px-5 sm:px-8">
    <div class="mb-12 max-w-3xl md:mb-14">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">{t.why.title}</h2>
      <p class="mt-5 text-[15px] leading-8 text-white/70 md:text-base">{t.why.lead}</p>
    </div>

    <div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-6">
      {t.why.stats.map((s) => (
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 text-center transition hover:border-white/20 hover:bg-white/[0.05]">
          <div class="text-4xl font-extrabold text-[color:var(--color-red-primary)] md:text-5xl">{s.value}</div>
          <div class="mt-2 text-xs font-medium text-white/70 md:text-sm">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
