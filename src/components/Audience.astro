---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const iconPaths: Record<string, string> = {
  code: 'M16 18l6-6-6-6 M8 6l-6 6 6 6 M14 4l-4 16',
  design: 'M12 19l7-7 3 3-7 7-3-3z M18 13l-1.5-7.5L2 2l3.5 14.5L13 18 M2 2l7.586 7.586 M11 11a2 2 0 11-4 0 2 2 0 014 0z',
  bulb: 'M9 18h6 M10 22h4 M12 2a7 7 0 00-4 12.7V17h8v-2.3A7 7 0 0012 2z',
  target: 'M12 22a10 10 0 100-20 10 10 0 000 20z M12 18a6 6 0 100-12 6 6 0 000 12z M12 14a2 2 0 100-4 2 2 0 000 4z',
  media: 'M23 7l-7 5 7 5V7z M14 5H3a2 2 0 00-2 2v10a2 2 0 002 2h11a2 2 0 002-2V7a2 2 0 00-2-2z',
  ai: 'M12 4a4 4 0 00-4 4v1a3 3 0 00-3 3 3 3 0 003 3v1a4 4 0 004 4 4 4 0 004-4v-1a3 3 0 003-3 3 3 0 00-3-3V8a4 4 0 00-4-4z M9 10h.01 M15 10h.01 M9 14l3 2 3-2',
  student: 'M12 3l10 5-10 5L2 8l10-5z M6 10v6c2 1.5 4 2 6 2s4-.5 6-2v-6 M22 8v6',
  spark: 'M12 2v4 M12 18v4 M2 12h4 M18 12h4 M5 5l3 3 M16 16l3 3 M5 19l3-3 M16 8l3-3',
  support: 'M21 12a9 9 0 10-18 0 9 9 0 0018 0z M3 12h6 M15 12h6 M9 9a3 3 0 016 0 M9 15a3 3 0 006 0',
};
const audience = t.audience;
---
<section id="audience" class="relative border-y border-white/5 bg-white/[0.02] py-20 md:py-28">
  <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mb-12 text-center md:mb-14">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">{audience.title}</h2>
      <p class="mt-3 text-[15px] leading-8 text-white/70">{audience.subtitle}</p>
    </div>

    <!-- Primary tier -->
    <div class="mb-4 flex flex-wrap items-baseline gap-3">
      <span class="inline-flex items-center rounded-full bg-[color:var(--color-red-primary)]/12 px-3 py-1 text-[10.5px] font-semibold uppercase tracking-[0.22em] text-[color:var(--color-red-primary)]">
        {audience.primary.label}
      </span>
      <span class="text-[14px] text-white/65 md:text-[14.5px]">{audience.primary.sublabel}</span>
    </div>

    <div class="mb-12 grid gap-4 md:grid-cols-3 md:gap-5">
      {audience.primary.items.map((it) => (
        <div class="flex items-start gap-4 rounded-2xl border border-[color:var(--color-red-primary)]/25 bg-gradient-to-br from-[color:var(--color-red-primary)]/8 via-white/[0.02] to-transparent p-5 transition hover:border-[color:var(--color-red-primary)]/45 md:p-6">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[color:var(--color-red-primary)] text-white shadow-[0_10px_30px_-10px_rgba(223,51,38,0.7)]">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[it.icon] ?? iconPaths.bulb}></path>
            </svg>
          </div>
          <div>
            <div class="text-[15px] font-bold text-white md:text-base">{it.title}</div>
            <div class="mt-1 text-[13px] leading-6 text-white/65 md:text-sm">{it.desc}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Specialisations tier -->
    <div class="mb-4 flex flex-wrap items-baseline gap-3">
      <span class="inline-flex items-center rounded-full bg-white/8 px-3 py-1 text-[10.5px] font-semibold uppercase tracking-[0.22em] text-white/85">
        {audience.specialisations.label}
      </span>
      <span class="text-[14px] text-white/65 md:text-[14.5px]">{audience.specialisations.sublabel}</span>
    </div>

    <div class="grid gap-4 md:grid-cols-2 md:gap-5 lg:grid-cols-3">
      {audience.specialisations.items.map((it) => (
        <div class="flex items-center gap-5 rounded-2xl border border-white/10 bg-white/[0.03] p-5 transition hover:border-white/20 hover:bg-white/[0.05] md:p-6">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-white/[0.05] text-[color:var(--color-red-primary)]">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[it.icon] ?? iconPaths.code}></path>
            </svg>
          </div>
          <div>
            <div class="text-[15px] font-bold text-white md:text-base">{it.title}</div>
            <div class="mt-1 text-[13px] text-white/60 md:text-sm">{it.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
