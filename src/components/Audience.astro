---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const audience = t.audience;
---
<section id="audience" class="relative border-y border-white/5 bg-white/[0.02] py-20 md:py-28">
  <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mx-auto mb-14 max-w-3xl text-center md:mb-16">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">{audience.title}</h2>
      <p class="mt-5 text-[15px] leading-8 text-white/70 md:text-base">{audience.description}</p>
    </div>

    <!-- 4 image cards -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 md:gap-6 lg:grid-cols-4">
      {audience.cards.map((c) => (
        <article class="group relative flex flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] transition hover:-translate-y-0.5 hover:border-white/20">
          <div class="relative aspect-[4/5] overflow-hidden">
            <img
              src={`${base}/images/audience/${c.image}`}
              alt={c.title}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.04]"
              loading="lazy"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[color:var(--color-black-primary)] via-[color:var(--color-black-primary)]/55 to-transparent"></div>
          </div>
          <div class="flex flex-1 flex-col p-6 md:p-7">
            <h3 class="text-lg font-bold text-white md:text-xl">{c.title}</h3>
            <p class="mt-2 text-[13.5px] leading-7 text-white/65 md:text-sm">{c.desc}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- Eligibility chips row -->
    <div class="mt-12 md:mt-14">
      <div class="mb-5 flex items-center gap-3">
        <span class="h-px flex-1 bg-white/10"></span>
        <span class="text-[10.5px] font-semibold uppercase tracking-[0.24em] text-white/55">{audience.eligibilityTitle}</span>
        <span class="h-px flex-1 bg-white/10"></span>
      </div>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 md:gap-4 lg:grid-cols-4">
        {audience.eligibility.map((e) => (
          <div class="flex items-center gap-3 rounded-2xl border border-[color:var(--color-red-primary)]/25 bg-[color:var(--color-red-primary)]/6 px-4 py-3.5 text-[13.5px] leading-6 text-white/90 md:text-sm">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[color:var(--color-red-primary)]/20 text-[color:var(--color-red-primary)]">
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12l5 5L20 7"></path>
              </svg>
            </span>
            <span>{e}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
