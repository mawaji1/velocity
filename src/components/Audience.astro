---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const iconPaths: Record<string, string> = {
  code: 'M16 18l6-6-6-6 M8 6l-6 6 6 6 M14 4l-4 16',
  design: 'M12 19l7-7 3 3-7 7-3-3z M18 13l-1.5-7.5L2 2l3.5 14.5L13 18 M2 2l7.586 7.586 M11 11a2 2 0 11-4 0 2 2 0 014 0z',
  bulb: 'M9 18h6 M10 22h4 M12 2a7 7 0 00-4 12.7V17h8v-2.3A7 7 0 0012 2z',
  target: 'M12 22a10 10 0 100-20 10 10 0 000 20z M12 18a6 6 0 100-12 6 6 0 000 12z M12 14a2 2 0 100-4 2 2 0 000 4z',
  media: 'M23 7l-7 5 7 5V7z M14 5H3a2 2 0 00-2 2v10a2 2 0 002 2h11a2 2 0 002-2V7a2 2 0 00-2-2z',
};
---
<section id="audience" class="relative border-y border-white/5 bg-white/[0.02] py-20 md:py-28">
  <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mb-12 max-w-3xl md:mb-14">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">{t.audience.title}</h2>
      <p class="mt-3 text-[15px] leading-8 text-white/70">{t.audience.subtitle}</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 md:gap-5 lg:grid-cols-3">
      {t.audience.items.map((it) => (
        <div class="flex items-center gap-5 rounded-2xl border border-white/10 bg-white/[0.03] p-5 transition hover:border-white/20 hover:bg-white/[0.05] md:p-6">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-white/[0.05] text-[color:var(--color-red-primary)]">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[it.icon] ?? iconPaths.code}></path>
            </svg>
          </div>
          <div>
            <div class="text-[15px] font-bold text-white md:text-base">{it.title}</div>
            <div class="mt-1 text-[13px] text-white/60 md:text-sm">{it.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
