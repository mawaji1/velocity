---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const ap = t.accelPipeline;
---
<section id="accelerator-pipeline" class="accel-section relative overflow-hidden border-y border-white/5 py-20 md:py-28">
  <!-- Top hairline + soft red glow behind heading (matches the rest of the redesigned sections) -->
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
  <div
    class="pointer-events-none absolute left-1/2 top-[-80px] h-[420px] w-[920px] -translate-x-1/2 rounded-full opacity-45"
    style="background: radial-gradient(closest-side, rgba(223,51,38,0.14), transparent 70%); filter: blur(28px);"
  ></div>

  <div class="relative mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mb-12 text-center md:mb-16">
      <h2 class="text-3xl font-extrabold tracking-tight text-white md:text-[44px] md:leading-tight">{ap.title}</h2>
      <div class="mx-auto mt-5 h-[3px] w-24 rounded-full bg-gradient-to-r from-transparent via-[color:var(--color-red-primary)] to-transparent"></div>
    </div>

    <div class="grid items-stretch gap-5 md:grid-cols-[1fr_auto_1fr] md:gap-4" data-accel>
      <!-- Left: Velocity (current) -->
      <article
        class="accel-card group relative flex flex-col overflow-hidden rounded-3xl border border-[color:var(--color-red-primary)]/35 bg-gradient-to-b from-[color:var(--color-red-primary)]/10 to-white/[0.03] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-[color:var(--color-red-primary)]/65 hover:bg-[color:var(--color-red-primary)]/[0.06] hover:shadow-[0_28px_70px_-25px_rgba(223,51,38,0.5)] md:p-8"
        style="--reveal-delay: 0ms;"
      >
        <!-- Top brand-red accent bar -->
        <div class="pointer-events-none absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-[color:var(--color-red-primary)]/0 via-[color:var(--color-red-primary)] to-[color:var(--color-red-primary)]/0 opacity-80"></div>

        <h3 class="text-2xl font-bold text-white md:text-[26px]">{ap.velocity.title}</h3>
        <p class="mt-1 text-[13.5px] text-white/65">{ap.velocity.desc}</p>

        <ul class="mt-5 space-y-2.5">
          {ap.velocity.bullets.map((b) => (
            <li class="flex items-start gap-2.5 text-[14px] text-white/85">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--color-red-primary)]"></span>
              <span>{b}</span>
            </li>
          ))}
        </ul>

        <!-- Bottom hairline that lights up on hover -->
        <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-[color:var(--color-red-primary)]/0 to-transparent transition-colors duration-500 group-hover:via-[color:var(--color-red-primary)]/65"></div>
      </article>

      <!-- Arrow connector -->
      <div class="accel-arrow flex items-center justify-center md:px-2" style="--reveal-delay: 100ms;">
        <div class="flex flex-col items-center gap-2 text-white/65">
          <svg viewBox="0 0 24 24" class="h-8 w-8 rotate-90 text-[color:var(--color-red-primary)] md:h-10 md:w-10 md:rotate-0 rtl:md:rotate-180" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14 M13 5l7 7-7 7"></path>
          </svg>
          <span class="text-[10.5px] font-semibold uppercase tracking-[0.22em] text-white/55">{ap.arrow}</span>
        </div>
      </div>

      <!-- Right: Accelerator (next phase) -->
      <article
        class="accel-card group relative flex flex-col overflow-hidden rounded-3xl border border-amber-300/30 bg-gradient-to-b from-amber-300/10 to-white/[0.03] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-amber-300/65 hover:bg-amber-300/[0.06] hover:shadow-[0_28px_70px_-25px_rgba(252,211,77,0.45)] md:p-8"
        style="--reveal-delay: 200ms;"
      >
        <!-- Top amber accent bar -->
        <div class="pointer-events-none absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-amber-300/0 via-amber-300 to-amber-300/0 opacity-80"></div>

        <h3 class="text-2xl font-bold text-white md:text-[26px]">{ap.accelerator.title}</h3>
        <p class="mt-1 text-[13.5px] text-amber-100/85">{ap.accelerator.desc}</p>

        <ul class="mt-5 space-y-2.5">
          {ap.accelerator.bullets.map((b) => (
            <li class="flex items-start gap-2.5 text-[14px] text-white/85">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-amber-300"></span>
              <span>{b}</span>
            </li>
          ))}
        </ul>

        <!-- Bottom hairline that lights up on hover -->
        <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-amber-300/0 to-transparent transition-colors duration-500 group-hover:via-amber-300/65"></div>
      </article>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>('[data-accel]');
  if (root) {
    const targets = Array.from(root.querySelectorAll<HTMLElement>('.accel-card, .accel-arrow'));
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!('IntersectionObserver' in window) || reduced) {
      targets.forEach((t) => t.classList.add('revealed'));
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('revealed');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.25 });
      targets.forEach((t) => io.observe(t));
    }
  }
</script>

<style>
  .accel-section {
    background: linear-gradient(180deg, var(--color-black-primary) 0%, rgba(255, 255, 255, 0.012) 50%, var(--color-black-primary) 100%);
  }
  .accel-card,
  .accel-arrow {
    opacity: 0;
    transform: translateY(28px);
  }
  .accel-card.revealed,
  .accel-arrow.revealed {
    animation: accel-in 760ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }
  @keyframes accel-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .accel-card,
    .accel-arrow {
      opacity: 1;
      transform: none;
      animation: none !important;
    }
  }
</style>
