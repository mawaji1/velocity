---
import type { Content } from '../i18n/content';
import { PROGRAM_START_ISO } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section class="hero-section relative overflow-hidden">
  <!-- Background -->
  <div class="hero-bg pointer-events-none absolute inset-0">
    <!-- Looping video background (silent, autoplay, loop) -->
    <video
      class="hero-video absolute inset-0 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={`${base}/videos/hero-poster.jpg`}
      aria-hidden="true"
    >
      <source src={`${base}/videos/hero.mp4`} type="video/mp4" />
      <source src={`${base}/videos/hero.webm`} type="video/webm" />
    </video>

    <!-- Darken video for text legibility (stronger on the start side for RTL title) -->
    <div class="absolute inset-0 bg-[linear-gradient(to_left,rgba(0,0,0,0.88)_0%,rgba(0,0,0,0.6)_45%,rgba(0,0,0,0.35)_100%)]"></div>
    <div class="absolute inset-0 bg-black/35"></div>

    <!-- Faint grid -->
    <div
      class="absolute inset-0 opacity-[0.05]"
      style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 80px 80px; mask-image: radial-gradient(ellipse at center, black 35%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse at center, black 35%, transparent 80%);"
    ></div>

    <!-- Soft top glow -->
    <div
      class="hero-glow-layer absolute top-[-25%] left-1/2 h-[700px] w-[1200px] -translate-x-1/2 rounded-full"
      style="background: radial-gradient(closest-side, rgba(223,51,38,0.22), transparent 70%);"
    ></div>

    <!-- Bottom vignette to blend hero into the next section -->
    <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[color:var(--color-black-primary)] to-transparent"></div>
  </div>

  <!-- Hero content: title block claims full focal area -->
  <div class="hero-content relative mx-auto max-w-[1280px] px-5 pt-20 pb-40 sm:px-8 md:pt-28 md:pb-48">
    <div class="text-start">
      <h1 class="hero-title text-[68px] font-extrabold leading-[0.95] tracking-tight text-white md:text-[120px] lg:text-[160px]">
        {t.hero.title}
      </h1>
      <div class="mt-6 h-[3px] w-24 rounded-full bg-gradient-to-r from-[color:var(--color-red-primary)] to-transparent md:w-32"></div>
      <p class="mt-6 max-w-[640px] text-[19px] font-medium leading-[1.5] text-white/85 md:mt-8 md:text-[26px] md:leading-[1.35]">
        {t.hero.subtitle}
      </p>
      <a
        href={t.hero.ctaPrimary.href}
        class="mt-8 inline-flex rounded-full bg-[color:var(--color-red-primary)] px-8 py-4 text-[15px] font-semibold text-white shadow-[0_16px_50px_-12px_rgba(223,51,38,0.7)] transition hover:-translate-y-0.5 hover:bg-[color:var(--color-red-primary-hover)] md:mt-10 md:text-[16px]"
      >
        {t.hero.ctaPrimary.label}
      </a>
    </div>
  </div>

  <!-- Countdown — pinned to bottom-end of hero (bottom-left in RTL, bottom-right in LTR).
       Static on mobile so it falls into normal flow at the end of the hero. -->
  <div
    class="hero-countdown relative z-[1] mx-auto mt-[-3rem] flex max-w-[1280px] flex-col gap-3 px-5 pb-10 sm:px-8 md:absolute md:bottom-8 md:end-8 md:mx-0 md:mt-0 md:max-w-none md:px-0 md:pb-0"
    data-countdown
    data-target={PROGRAM_START_ISO}
    data-live-text={t.countdown.live}
    data-lang={t.lang}
  >
    <div class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[color:var(--color-red-primary)] md:text-[11px]">
      {t.countdown.title}
    </div>
    <div class="flex items-end gap-3 md:gap-4" data-countdown-units>
      {(['days', 'hours', 'minutes', 'seconds'] as const).map((key) => (
        <div class="ring-cell flex flex-col items-center gap-1.5">
          <div class="relative h-[58px] w-[58px] md:h-[68px] md:w-[68px]">
            <svg class="absolute inset-0 h-full w-full -rotate-90" viewBox="0 0 64 64" aria-hidden="true">
              <circle cx="32" cy="32" r="28" fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="3.5"></circle>
              <circle
                class="ring-progress"
                cx="32" cy="32" r="28"
                fill="none"
                stroke="var(--color-red-primary)"
                stroke-width="3.5"
                stroke-linecap="round"
                stroke-dasharray="175.93"
                stroke-dashoffset="175.93"
                data-progress
                data-unit={key}
              ></circle>
            </svg>
            <span
              class="absolute inset-0 flex items-center justify-center text-[18px] font-bold tabular-nums text-white md:text-[22px]"
              data-unit={key}
            >--</span>
          </div>
          <span class="text-[9px] uppercase tracking-[0.15em] text-white/60 md:text-[10px]">{t.countdown.units[key]}</span>
        </div>
      ))}
    </div>
    <div class="hidden text-sm font-semibold text-white" data-countdown-live></div>
  </div>
</section>

<script>
  const el = document.querySelector<HTMLElement>('[data-countdown]');
  if (el) {
    const target = new Date(el.dataset.target ?? '').getTime();
    const liveText = el.dataset.liveText ?? '';
    const lang = el.dataset.lang ?? 'en';
    const units = el.querySelector<HTMLElement>('[data-countdown-units]');
    const live = el.querySelector<HTMLElement>('[data-countdown-live]');
    const arDigits = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
    const CIRC = 2 * Math.PI * 28; // matches r="28" in the SVG ring
    const fmt = (n: number) => {
      const s = String(n).padStart(2, '0');
      return lang === 'ar' ? s.replace(/\d/g, (d) => arDigits[+d]) : s;
    };
    const setText = (name: string, value: number) => {
      const node = el.querySelector<HTMLElement>(`span[data-unit="${name}"]`);
      if (node) node.textContent = fmt(value);
    };
    const setRing = (name: string, value: number, max: number) => {
      const ring = el.querySelector<SVGCircleElement>(`circle[data-progress][data-unit="${name}"]`);
      if (!ring) return;
      const ratio = max > 0 ? Math.min(value, max) / max : 0;
      ring.setAttribute('stroke-dashoffset', String(CIRC * (1 - ratio)));
    };
    // Lock the days axis to the initial remaining count so the ring drains smoothly across the program.
    const initialDiff = target - Date.now();
    const maxDays = Math.max(1, Math.ceil(initialDiff / 86_400_000));
    const tick = () => {
      const diff = target - Date.now();
      if (diff <= 0) {
        if (units) units.classList.add('hidden');
        if (live) {
          live.textContent = liveText;
          live.classList.remove('hidden');
        }
        return;
      }
      const sec = Math.floor(diff / 1000);
      const d = Math.floor(sec / 86400);
      const h = Math.floor((sec % 86400) / 3600);
      const m = Math.floor((sec % 3600) / 60);
      const s = sec % 60;
      setText('days', d);    setRing('days',    d, maxDays);
      setText('hours', h);   setRing('hours',   h, 24);
      setText('minutes', m); setRing('minutes', m, 60);
      setText('seconds', s); setRing('seconds', s, 60);
    };
    tick();
    setInterval(tick, 1000);
  }
</script>

<style>
  .hero-section {
    min-height: 600px;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    transform: translateZ(0);
  }
  .hero-bg {
    z-index: 0;
    will-change: transform;
    transform: translateZ(0);
  }
  .hero-glow-layer {
    filter: blur(18px);
    will-change: transform, filter;
    transform: translate3d(0, 0, 0);
  }
  .hero-title {
    text-shadow: 0 6px 50px rgba(223, 51, 38, 0.2);
  }
  .hero-video {
    /* Subtle desaturation so footage harmonizes with the brand red overlay */
    filter: saturate(0.85) contrast(1.05);
  }
  .ring-progress {
    transition: stroke-dashoffset 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .ring-progress { transition: none; }
  }
  @media (max-width: 640px) {
    .hero-glow-layer {
      filter: blur(10px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      display: none;
    }
    /* Use poster image as a still background instead */
    .hero-bg::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url('/velocity/videos/hero-poster.jpg') center/cover no-repeat;
    }
  }
  .partner-logo-invert {
    filter: brightness(0) invert(1);
  }
</style>


