---
import type { Content } from '../i18n/content';
import { PROGRAM_START_ISO } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const infoIcons: Record<string, string> = {
  clock: 'M12 7v5l3 2 M12 22a10 10 0 100-20 10 10 0 000 20z',
  pin: 'M12 22s-7-7.58-7-13a7 7 0 1114 0c0 5.42-7 13-7 13z M12 11a2 2 0 100-4 2 2 0 000 4z',
  users: 'M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2 M9 11a4 4 0 100-8 4 4 0 000 8z M22 21v-2a4 4 0 00-3-3.87 M16 3.13A4 4 0 0119 7a4 4 0 01-3 3.87',
  target: 'M12 22a10 10 0 100-20 10 10 0 000 20z M12 18a6 6 0 100-12 6 6 0 000 12z M12 14a2 2 0 100-4 2 2 0 000 4z',
  cloud: 'M17.5 19a4.5 4.5 0 100-9h-1.26A8 8 0 104 16.25',
  trophy: 'M8 21h8 M12 17v4 M6 3h12v4a6 6 0 01-12 0V3z M6 5H3v2a3 3 0 003 3 M18 5h3v2a3 3 0 01-3 3',
};
---
<section class="hero-section relative overflow-hidden">
  <!-- Background only: stadium-light glow + subtle grid + ambient motion arcs -->
  <div class="hero-bg pointer-events-none absolute inset-0">
    <!-- Subtle grid with radial fade -->
    <div
      class="absolute inset-0 opacity-[0.06]"
      style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 72px 72px; mask-image: radial-gradient(ellipse at center, black 40%, transparent 82%); -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 82%);"
    ></div>

    <!-- Top-center stadium glow -->
    <div
      class="hero-glow-layer absolute top-[-12%] left-1/2 h-[900px] w-[900px] -translate-x-1/2 rounded-full"
      style="background: radial-gradient(closest-side, rgba(223,51,38,0.28), transparent 72%);"
    ></div>
    <!-- Secondary side glows (stadium floodlights) -->
    <div
      class="hero-glow-layer absolute top-[14%] left-[8%] h-[320px] w-[320px] rounded-full"
      style="background: radial-gradient(closest-side, rgba(255,255,255,0.06), transparent 70%);"
    ></div>
    <div
      class="hero-glow-layer absolute top-[10%] right-[10%] h-[360px] w-[360px] rounded-full"
      style="background: radial-gradient(closest-side, rgba(255,255,255,0.05), transparent 70%);"
    ></div>

    <!-- Ambient motion arcs (very subtle, behind the title) -->
    <svg class="absolute inset-x-0 top-0 h-full w-full" viewBox="0 0 1440 820" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <linearGradient id="hero-arc-a" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#df3326" stop-opacity="0"></stop>
          <stop offset="50%" stop-color="#df3326" stop-opacity="0.55"></stop>
          <stop offset="100%" stop-color="#df3326" stop-opacity="0"></stop>
        </linearGradient>
        <linearGradient id="hero-arc-b" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#ffffff" stop-opacity="0"></stop>
          <stop offset="50%" stop-color="#ffffff" stop-opacity="0.18"></stop>
          <stop offset="100%" stop-color="#ffffff" stop-opacity="0"></stop>
        </linearGradient>
      </defs>
      <path d="M-40 640 Q 720 380 1480 640" fill="none" stroke="url(#hero-arc-a)" stroke-width="2" opacity="0.6" />
      <path d="M-40 700 Q 720 460 1480 700" fill="none" stroke="url(#hero-arc-b)" stroke-width="1" opacity="0.6" />
      <path d="M-40 760 Q 720 540 1480 760" fill="none" stroke="url(#hero-arc-b)" stroke-width="1" opacity="0.5" />
    </svg>

    <!-- Bottom vignette -->
    <div class="absolute inset-x-0 bottom-0 h-36 bg-gradient-to-t from-[color:var(--color-black-primary)] to-transparent"></div>
  </div>

  <!-- Hero content: centered text only -->
  <div class="hero-content relative mx-auto max-w-[960px] px-5 pt-20 pb-16 text-center sm:px-8 md:pt-28 md:pb-20">
    {t.hero.editionBadge && (
      <div class="mx-auto mb-6 inline-flex items-center gap-2 rounded-full border border-amber-300/35 bg-amber-300/8 px-3.5 py-1.5 text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-200/95 backdrop-blur md:text-[12px]">
        <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2l2.39 4.84 5.34.78-3.86 3.77.91 5.32L12 14.27 7.22 16.71l.91-5.32L4.27 7.62l5.34-.78z"></path>
        </svg>
        <span>{t.hero.editionBadge}</span>
      </div>
    )}
    <h1 class="text-[56px] font-extrabold leading-[1.05] tracking-tight text-white md:text-[104px]">
      {t.hero.title}
    </h1>
    <div class="mx-auto mt-5 h-[3px] w-24 rounded-full bg-gradient-to-r from-transparent via-[color:var(--color-red-primary)] to-transparent md:w-32"></div>

    <p class="mx-auto mt-7 max-w-3xl text-[15px] leading-8 text-white/75 md:text-lg md:leading-9">
      {t.hero.lead}
    </p>

    <!-- Primary CTA -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href={t.hero.ctaPrimary.href}
        class="rounded-full bg-[color:var(--color-red-primary)] px-7 py-3.5 text-[14px] font-semibold text-white shadow-[0_16px_50px_-12px_rgba(223,51,38,0.7)] transition hover:-translate-y-0.5 hover:bg-[color:var(--color-red-primary-hover)] md:text-[15px]"
      >
        {t.hero.ctaPrimary.label}
      </a>
    </div>

    <!-- Deadlines: Priority + Registration close -->
    <div class="mt-6 flex flex-wrap items-center justify-center gap-2.5">
      {t.hero.priorityDeadlineLabel && (
        <div class="inline-flex items-center gap-2.5 rounded-full border border-amber-300/35 bg-amber-300/8 px-3.5 py-1.5 text-[11px] backdrop-blur md:text-[12px]">
          <span class="h-1.5 w-1.5 rounded-full bg-amber-300"></span>
          <span class="font-medium text-white/70">{t.hero.priorityDeadlineLabel}</span>
          <span class="font-semibold text-white">{t.hero.priorityDeadlineValue}</span>
        </div>
      )}
      <div class="inline-flex items-center gap-2.5 rounded-full border border-[color:var(--color-red-primary)]/45 bg-[color:var(--color-red-primary)]/12 px-3.5 py-1.5 text-[11px] backdrop-blur md:text-[12px]">
        <span class="relative flex h-2 w-2">
          <span class="absolute inset-0 animate-ping rounded-full bg-[color:var(--color-red-primary)] opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-[color:var(--color-red-primary)]"></span>
        </span>
        <span class="font-medium text-white/75">{t.hero.deadlineLabel}</span>
        <span class="font-bold text-white">{t.hero.deadlineValue}</span>
      </div>
    </div>

    <!-- Countdown (inside hero) -->
    <div
      class="mx-auto mt-12 max-w-[720px] rounded-3xl border border-white/10 bg-white/[0.04] p-5 backdrop-blur md:mt-14 md:p-6"
      data-countdown
      data-target={PROGRAM_START_ISO}
      data-live-text={t.countdown.live}
    >
      <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[color:var(--color-red-primary)]">
        {t.countdown.title}
      </div>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-2.5 md:gap-4" data-countdown-units>
        <div class="flex min-w-[70px] flex-col items-center rounded-2xl border border-white/10 bg-black/30 px-3 py-3 md:min-w-[82px]">
          <span class="text-2xl font-bold tabular-nums text-white md:text-4xl" data-unit="days">--</span>
          <span class="mt-1 text-[11px] text-white/60">{t.countdown.units.days}</span>
        </div>
        <div class="flex min-w-[70px] flex-col items-center rounded-2xl border border-white/10 bg-black/30 px-3 py-3 md:min-w-[82px]">
          <span class="text-2xl font-bold tabular-nums text-white md:text-4xl" data-unit="hours">--</span>
          <span class="mt-1 text-[11px] text-white/60">{t.countdown.units.hours}</span>
        </div>
        <div class="flex min-w-[70px] flex-col items-center rounded-2xl border border-white/10 bg-black/30 px-3 py-3 md:min-w-[82px]">
          <span class="text-2xl font-bold tabular-nums text-white md:text-4xl" data-unit="minutes">--</span>
          <span class="mt-1 text-[11px] text-white/60">{t.countdown.units.minutes}</span>
        </div>
        <div class="flex min-w-[70px] flex-col items-center rounded-2xl border border-white/10 bg-black/30 px-3 py-3 md:min-w-[82px]">
          <span class="text-2xl font-bold tabular-nums text-white md:text-4xl" data-unit="seconds">--</span>
          <span class="mt-1 text-[11px] text-white/60">{t.countdown.units.seconds}</span>
        </div>
      </div>
      <div class="mt-4 hidden text-sm font-semibold text-white" data-countdown-live></div>
    </div>

    <!-- Partner logos (inside hero) -->
    <div class="mx-auto mt-12 max-w-[860px] md:mt-14">
      <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white/55">
        {t.partners.title}
      </div>
      <div class="mt-5 flex flex-wrap items-center justify-center gap-x-10 gap-y-6 md:gap-x-14">
        {t.partners.items.map((p) => (
          <img
            src={`${base}/images/partners/${p.logo}`}
            alt={p.name}
            class={`max-h-12 w-auto max-w-[160px] object-contain opacity-80 transition hover:opacity-100 md:max-h-14 ${p.invert ? 'partner-logo-invert' : ''}`}
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const el = document.querySelector<HTMLElement>('[data-countdown]');
  if (el) {
    const target = new Date(el.dataset.target ?? '').getTime();
    const liveText = el.dataset.liveText ?? '';
    const units = el.querySelector<HTMLElement>('[data-countdown-units]');
    const live = el.querySelector<HTMLElement>('[data-countdown-live]');
    const set = (name: string, value: number) => {
      const node = el.querySelector<HTMLElement>(`[data-unit="${name}"]`);
      if (node) node.textContent = String(value).padStart(2, '0');
    };
    const tick = () => {
      const diff = target - Date.now();
      if (diff <= 0) {
        if (units) units.classList.add('hidden');
        if (live) {
          live.textContent = liveText;
          live.classList.remove('hidden');
        }
        return;
      }
      const sec = Math.floor(diff / 1000);
      set('days', Math.floor(sec / 86400));
      set('hours', Math.floor((sec % 86400) / 3600));
      set('minutes', Math.floor((sec % 3600) / 60));
      set('seconds', sec % 60);
    };
    tick();
    setInterval(tick, 1000);
  }
</script>

<style>
  /* Ensure the hero always has space and its content is composited above
     decorative blurred layers — fixes iOS/Safari mobile where heavy
     `filter: blur()` on large absolute layers could delay first paint
     and make the hero look empty until a scroll repaint. */
  .hero-section {
    min-height: 520px;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    transform: translateZ(0);
  }
  .hero-bg {
    z-index: 0;
    will-change: transform;
    transform: translateZ(0);
  }
  .hero-glow-layer {
    filter: blur(14px);
    will-change: transform, filter;
    transform: translate3d(0, 0, 0);
  }
  /* Lighter blur radius on small screens — iOS Safari's compositor
     struggles with large blurred surfaces and can fail to paint them
     until a scroll event. */
  @media (max-width: 640px) {
    .hero-glow-layer {
      filter: blur(8px);
    }
  }
  .partner-logo-invert {
    filter: brightness(0) invert(1);
  }
</style>

<!-- Info-bar: 4 stat tiles (Duration · Online · On-site · Prizes) -->
<section class="relative border-y border-white/5 bg-white/[0.03]">
  <div class="mx-auto grid max-w-[1240px] grid-cols-2 lg:grid-cols-4">
    {t.infobar.map((item, i) => (
      <div
        class={`relative flex items-start gap-4 px-5 py-5 text-start md:px-6 md:py-7 ${i < t.infobar.length - 1 ? 'after:pointer-events-none after:absolute after:inset-x-5 after:bottom-0 after:h-px after:bg-white/10 lg:after:inset-x-0 lg:after:inset-y-6 lg:after:end-0 lg:after:bottom-auto lg:after:h-auto lg:after:w-px' : ''}`}
      >
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[color:var(--color-red-primary)]/15 text-[color:var(--color-red-primary)] ring-1 ring-inset ring-[color:var(--color-red-primary)]/25">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d={infoIcons[item.icon] ?? infoIcons.target}></path>
          </svg>
        </div>
        <div class="min-w-0">
          <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white/55">{item.label}</div>
          <div class="mt-1.5 text-[13px] font-semibold leading-6 text-white md:text-[14px]">{item.value}</div>
        </div>
      </div>
    ))}
  </div>
</section>
