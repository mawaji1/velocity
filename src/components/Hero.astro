---
import type { Content } from '../i18n/content';
import { PROGRAM_START_ISO } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const infoIcons: Record<string, string> = {
  clock: 'M12 7v5l3 2 M12 22a10 10 0 100-20 10 10 0 000 20z',
  pin: 'M12 22s-7-7.58-7-13a7 7 0 1114 0c0 5.42-7 13-7 13z M12 11a2 2 0 100-4 2 2 0 000 4z',
  users: 'M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2 M9 11a4 4 0 100-8 4 4 0 000 8z M22 21v-2a4 4 0 00-3-3.87 M16 3.13A4 4 0 0119 7a4 4 0 01-3 3.87',
  target: 'M12 22a10 10 0 100-20 10 10 0 000 20z M12 18a6 6 0 100-12 6 6 0 000 12z M12 14a2 2 0 100-4 2 2 0 000 4z',
  cloud: 'M17.5 19a4.5 4.5 0 100-9h-1.26A8 8 0 104 16.25',
  trophy: 'M8 21h8 M12 17v4 M6 3h12v4a6 6 0 01-12 0V3z M6 5H3v2a3 3 0 003 3 M18 5h3v2a3 3 0 01-3 3',
};
---
<section class="hero-section relative overflow-hidden">
  <!-- Background -->
  <div class="hero-bg pointer-events-none absolute inset-0">
    <!-- Faint grid -->
    <div
      class="absolute inset-0 opacity-[0.05]"
      style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 80px 80px; mask-image: radial-gradient(ellipse at center, black 35%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse at center, black 35%, transparent 80%);"
    ></div>

    <!-- Soft top glow -->
    <div
      class="hero-glow-layer absolute top-[-25%] left-1/2 h-[700px] w-[1200px] -translate-x-1/2 rounded-full"
      style="background: radial-gradient(closest-side, rgba(223,51,38,0.22), transparent 70%);"
    ></div>

    <!-- Bottom vignette to blend hero into the next section -->
    <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[color:var(--color-black-primary)] to-transparent"></div>
  </div>

  <!-- Hero content: 2-column grid -->
  <div class="hero-content relative mx-auto max-w-[1280px] px-5 pt-20 pb-24 sm:px-8 md:pt-28 md:pb-32">
    <div class="grid items-center gap-12 md:grid-cols-[1.05fr_1fr] md:gap-14 lg:gap-20">
      <!-- Title block (right in RTL via natural grid order) -->
      <div class="text-start">
        <h1 class="hero-title text-[68px] font-extrabold leading-[0.95] tracking-tight text-white md:text-[120px] lg:text-[140px]">
          {t.hero.title}
        </h1>
        <div class="mt-6 h-[3px] w-24 rounded-full bg-gradient-to-r from-[color:var(--color-red-primary)] to-transparent md:w-32"></div>
        <p class="mt-6 max-w-[520px] text-[19px] font-medium leading-[1.5] text-white/80 md:mt-8 md:text-[26px] md:leading-[1.35]">
          {t.hero.subtitle}
        </p>
        <a
          href={t.hero.ctaPrimary.href}
          class="mt-8 inline-flex rounded-full bg-[color:var(--color-red-primary)] px-8 py-4 text-[15px] font-semibold text-white shadow-[0_16px_50px_-12px_rgba(223,51,38,0.7)] transition hover:-translate-y-0.5 hover:bg-[color:var(--color-red-primary-hover)] md:mt-10 md:text-[16px]"
        >
          {t.hero.ctaPrimary.label}
        </a>
      </div>

      <!-- Countdown + partners stack (left in RTL via natural grid order) -->
      <div class="flex flex-col gap-7 md:gap-9">
        <!-- Countdown -->
        <div
          class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 backdrop-blur md:p-7"
          data-countdown
          data-target={PROGRAM_START_ISO}
          data-live-text={t.countdown.live}
          data-lang={t.lang}
        >
          <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[color:var(--color-red-primary)]">
            {t.countdown.title}
          </div>
          <div class="mt-5 grid grid-cols-4 gap-2 md:gap-3" data-countdown-units>
            <div class="flex flex-col items-center rounded-2xl border border-white/10 bg-black/30 px-1.5 py-3.5 md:px-2 md:py-4">
              <span class="text-[28px] font-bold tabular-nums text-white md:text-[42px]" data-unit="days">--</span>
              <span class="mt-1 text-[10px] text-white/60 md:text-[11px]">{t.countdown.units.days}</span>
            </div>
            <div class="flex flex-col items-center rounded-2xl border border-white/10 bg-black/30 px-1.5 py-3.5 md:px-2 md:py-4">
              <span class="text-[28px] font-bold tabular-nums text-white md:text-[42px]" data-unit="hours">--</span>
              <span class="mt-1 text-[10px] text-white/60 md:text-[11px]">{t.countdown.units.hours}</span>
            </div>
            <div class="flex flex-col items-center rounded-2xl border border-white/10 bg-black/30 px-1.5 py-3.5 md:px-2 md:py-4">
              <span class="text-[28px] font-bold tabular-nums text-white md:text-[42px]" data-unit="minutes">--</span>
              <span class="mt-1 text-[10px] text-white/60 md:text-[11px]">{t.countdown.units.minutes}</span>
            </div>
            <div class="flex flex-col items-center rounded-2xl border border-white/10 bg-black/30 px-1.5 py-3.5 md:px-2 md:py-4">
              <span class="text-[28px] font-bold tabular-nums text-white md:text-[42px]" data-unit="seconds">--</span>
              <span class="mt-1 text-[10px] text-white/60 md:text-[11px]">{t.countdown.units.seconds}</span>
            </div>
          </div>
          <div class="mt-4 hidden text-sm font-semibold text-white" data-countdown-live></div>
        </div>

        <!-- Partners -->
        <div>
          <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white/55">
            {t.partners.title}
          </div>
          <div class="mt-4 flex flex-wrap items-center gap-x-8 gap-y-4 md:gap-x-12">
            {t.partners.items.map((p) => (
              <img
                src={`${base}/images/partners/${p.logo}`}
                alt={p.name}
                class={`max-h-11 w-auto max-w-[140px] object-contain opacity-85 transition hover:opacity-100 md:max-h-14 ${p.invert ? 'partner-logo-invert' : ''}`}
                loading="lazy"
              />
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const el = document.querySelector<HTMLElement>('[data-countdown]');
  if (el) {
    const target = new Date(el.dataset.target ?? '').getTime();
    const liveText = el.dataset.liveText ?? '';
    const lang = el.dataset.lang ?? 'en';
    const units = el.querySelector<HTMLElement>('[data-countdown-units]');
    const live = el.querySelector<HTMLElement>('[data-countdown-live]');
    const arDigits = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
    const fmt = (n: number) => {
      const s = String(n).padStart(2, '0');
      return lang === 'ar' ? s.replace(/\d/g, (d) => arDigits[+d]) : s;
    };
    const set = (name: string, value: number) => {
      const node = el.querySelector<HTMLElement>(`[data-unit="${name}"]`);
      if (node) node.textContent = fmt(value);
    };
    const tick = () => {
      const diff = target - Date.now();
      if (diff <= 0) {
        if (units) units.classList.add('hidden');
        if (live) {
          live.textContent = liveText;
          live.classList.remove('hidden');
        }
        return;
      }
      const sec = Math.floor(diff / 1000);
      set('days', Math.floor(sec / 86400));
      set('hours', Math.floor((sec % 86400) / 3600));
      set('minutes', Math.floor((sec % 3600) / 60));
      set('seconds', sec % 60);
    };
    tick();
    setInterval(tick, 1000);
  }
</script>

<style>
  .hero-section {
    min-height: 600px;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    transform: translateZ(0);
  }
  .hero-bg {
    z-index: 0;
    will-change: transform;
    transform: translateZ(0);
  }
  .hero-glow-layer {
    filter: blur(18px);
    will-change: transform, filter;
    transform: translate3d(0, 0, 0);
  }
  .hero-title {
    text-shadow: 0 6px 50px rgba(223, 51, 38, 0.2);
  }
  @media (max-width: 640px) {
    .hero-glow-layer {
      filter: blur(10px);
    }
  }
  .partner-logo-invert {
    filter: brightness(0) invert(1);
  }
</style>

<!-- Info-bar: 4 stat tiles (Duration · Online · On-site · Prizes) -->
<section class="relative border-y border-white/5 bg-white/[0.03]">
  <div class="mx-auto grid max-w-[1240px] grid-cols-2 lg:grid-cols-4">
    {t.infobar.map((item, i) => (
      <div
        class={`relative flex items-start gap-4 px-5 py-5 text-start md:px-6 md:py-7 ${i < t.infobar.length - 1 ? 'after:pointer-events-none after:absolute after:inset-x-5 after:bottom-0 after:h-px after:bg-white/10 lg:after:inset-x-0 lg:after:inset-y-6 lg:after:end-0 lg:after:bottom-auto lg:after:h-auto lg:after:w-px' : ''}`}
      >
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[color:var(--color-red-primary)]/15 text-[color:var(--color-red-primary)] ring-1 ring-inset ring-[color:var(--color-red-primary)]/25">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d={infoIcons[item.icon] ?? infoIcons.target}></path>
          </svg>
        </div>
        <div class="min-w-0">
          <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white/55">{item.label}</div>
          {('currencyIcon' in item && item.currencyIcon) ? (
            <div class="mt-1.5 flex items-baseline gap-2 text-[13px] font-semibold leading-6 text-white md:text-[14px]">
              {('valuePrefix' in item && item.valuePrefix) && (
                <span>{item.valuePrefix}</span>
              )}
              <span class="flex items-baseline gap-1.5 rtl:flex-row-reverse">
                <img
                  src={`${base}/images/sar.svg`}
                  alt="SAR"
                  class="h-4 w-auto md:h-[18px]"
                  style="filter: brightness(0) invert(1);"
                />
                <span class="tabular-nums">{item.value}</span>
              </span>
            </div>
          ) : (
            <div class="mt-1.5 text-[13px] font-semibold leading-6 text-white md:text-[14px]">{item.value}</div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
