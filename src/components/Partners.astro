---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
---
<section id="partners" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mb-12 text-center md:mb-14">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">{t.partners.title}</h2>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-3 md:gap-6">
      {t.partners.items.map((p) => (
        <div class="flex h-28 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] px-6 text-center transition hover:border-white/20 hover:bg-white/[0.05] md:h-32">
          <span class="text-base font-semibold text-white/85 md:text-lg">{p.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
