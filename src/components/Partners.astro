---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section id="partners" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mb-12 text-center md:mb-14">
      <h2 class="text-3xl font-bold text-white md:text-4xl">{t.partners.title}</h2>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-3 md:gap-6">
      {t.partners.items.map((p) => (
        <div class="group relative flex h-36 items-center justify-center overflow-hidden rounded-3xl border border-white/10 bg-white/[0.04] px-8 transition hover:border-white/25 hover:bg-white/[0.06] md:h-40">
          <img
            src={`${base}/images/partners/${p.logo}`}
            alt={p.name}
            class={`max-h-20 w-auto max-w-[220px] object-contain opacity-85 transition duration-300 group-hover:scale-[1.03] group-hover:opacity-100 md:max-h-24 ${p.invert ? 'partner-logo-invert' : ''}`}
            loading="lazy"
          />
          <span class="sr-only">{p.name}</span>
          <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-[color:var(--color-red-primary)]/40 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .partner-logo-invert {
    filter: brightness(0) invert(1);
  }
</style>
