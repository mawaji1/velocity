---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const audience = t.audience;

const arDigits = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
const formatNumber = (n: number) => {
  const s = String(n).padStart(2, '0');
  return t.lang === 'ar' ? s.replace(/\d/g, (d) => arDigits[+d]) : s;
};
---
<section id="eligibility" class="eligibility-section relative overflow-hidden py-20 md:py-28">
  <!-- Subtle top hairline -->
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
  <!-- Soft accent glow behind heading (matches other sections, not stronger) -->
  <div
    class="pointer-events-none absolute left-1/2 top-[-80px] h-[420px] w-[920px] -translate-x-1/2 rounded-full opacity-40"
    style="background: radial-gradient(closest-side, rgba(223,51,38,0.13), transparent 70%); filter: blur(28px);"
  ></div>

  <div class="relative mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mx-auto mb-12 max-w-3xl text-center md:mb-16">
      <h2 class="text-3xl font-extrabold tracking-tight text-white md:text-[48px] md:leading-tight">{audience.eligibilityTitle}</h2>
      <div class="mx-auto mt-5 h-[3px] w-28 rounded-full bg-gradient-to-r from-transparent via-[color:var(--color-red-primary)] to-transparent"></div>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-3 sm:gap-5 lg:gap-6" data-eligibility>
      {audience.eligibility.map((item, i) => (
        <article
          class="eligibility-card group relative flex min-h-[220px] flex-col justify-between overflow-hidden rounded-3xl border border-white/12 bg-white/[0.025] p-7 transition-all duration-300 hover:-translate-y-1 hover:border-[color:var(--color-red-primary)]/45 hover:bg-white/[0.04] hover:shadow-[0_28px_70px_-30px_rgba(223,51,38,0.4)] md:min-h-[250px] md:p-9"
          style={`--reveal-delay: ${i * 110}ms;`}
        >
          <!-- Top brand-red accent bar (single red touch) -->
          <div class="pointer-events-none absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-[color:var(--color-red-primary)]/0 via-[color:var(--color-red-primary)] to-[color:var(--color-red-primary)]/0 opacity-80"></div>

          <!-- Decorative big number on the end side -->
          <div class="pointer-events-none absolute end-5 top-3 text-[64px] font-extrabold leading-none text-white/8 tabular-nums md:end-7 md:top-4 md:text-[88px]">
            {formatNumber(i + 1)}
          </div>

          <!-- Check badge -->
          <div class="check-badge relative inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[color:var(--color-red-primary)]/15 ring-1 ring-inset ring-[color:var(--color-red-primary)]/35 md:h-14 md:w-14">
            <div class="absolute -inset-2 -z-10 rounded-2xl bg-[color:var(--color-red-primary)]/0 blur-md transition-colors duration-500 group-hover:bg-[color:var(--color-red-primary)]/30"></div>
            <svg viewBox="0 0 24 24" class="h-6 w-6 text-[color:var(--color-red-primary)] md:h-7 md:w-7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12l5 5L20 7"></path>
            </svg>
          </div>

          <!-- Item text -->
          <p class="relative mt-6 text-[15px] font-semibold leading-7 text-white/95 md:text-[17px] md:leading-8">{item}</p>

          <!-- Bottom hairline that lights up on hover -->
          <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-[color:var(--color-red-primary)]/0 to-transparent transition-colors duration-500 group-hover:via-[color:var(--color-red-primary)]/60"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>('[data-eligibility]');
  if (root) {
    const cards = Array.from(root.querySelectorAll<HTMLElement>('.eligibility-card'));
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!('IntersectionObserver' in window) || reduced) {
      cards.forEach((c) => c.classList.add('revealed'));
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('revealed');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.25 });
      cards.forEach((c) => io.observe(c));
    }
  }
</script>

<style>
  .eligibility-section {
    background: linear-gradient(180deg, var(--color-black-primary) 0%, rgba(255, 255, 255, 0.012) 50%, var(--color-black-primary) 100%);
  }
  .eligibility-card {
    opacity: 0;
    transform: translateY(28px);
  }
  .eligibility-card.revealed {
    animation: eligibility-card-in 760ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }
  @keyframes eligibility-card-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .eligibility-card {
      opacity: 1;
      transform: none;
      animation: none !important;
    }
  }
</style>
