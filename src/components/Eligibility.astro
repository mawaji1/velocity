---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const e = t.eligibility;
---
<section id="eligibility" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-[1100px] px-5 sm:px-8">
    <div class="mb-10 text-center md:mb-12">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">{e.title}</h2>
      <p class="mt-3 text-[15px] text-white/60">{e.subtitle}</p>
    </div>

    <div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6 md:p-10">
      <ul class="grid gap-3 sm:grid-cols-2 md:gap-4">
        {e.items.map((item) => (
          <li class="flex items-start gap-3 rounded-2xl border border-white/8 bg-black/25 px-4 py-3 text-[14px] text-white/85 md:py-3.5 md:text-[14.5px]">
            <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[color:var(--color-red-primary)]/15 text-[color:var(--color-red-primary)]">
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6L9 17l-5-5"></path>
              </svg>
            </span>
            <span>{item}</span>
          </li>
        ))}
      </ul>

      {e.note && (
        <div class="mt-6 rounded-2xl border border-amber-300/25 bg-amber-300/6 px-5 py-4 text-[13.5px] leading-7 text-amber-100/95 md:text-[14px]">
          <span class="me-2 inline-flex h-5 items-center rounded-full bg-amber-300/20 px-2 text-[10.5px] font-semibold uppercase tracking-[0.16em] text-amber-100">●</span>
          {e.note}
        </div>
      )}
    </div>
  </div>
</section>
