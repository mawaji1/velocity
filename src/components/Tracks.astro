---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
---
<section id="tracks" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mb-12 text-center md:mb-16">
      <h2 class="text-3xl font-extrabold tracking-tight text-white md:text-[44px] md:leading-tight">{t.tracks.title}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-[15px] text-white/70">{t.tracks.lead}</p>
      <div class="mx-auto mt-5 h-[3px] w-24 rounded-full bg-gradient-to-r from-transparent via-[color:var(--color-red-primary)] to-transparent"></div>
    </div>

    <div class="flex flex-col gap-4 md:gap-5">
      {t.tracks.items.map((track, idx) => (
        <details
          class="group relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] transition hover:border-white/20"
          open={idx === 0}
        >
          <summary class="flex cursor-pointer items-center gap-5 p-5 md:gap-7 md:p-7">
            <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[color:var(--color-red-primary)] text-xl font-bold text-white shadow-[0_10px_30px_-10px_rgba(223,51,38,0.7)] md:h-16 md:w-16 md:text-2xl">
              {track.n}
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-xl font-bold text-white md:text-2xl">{track.title}</h3>
              <p class="mt-2 line-clamp-2 text-sm leading-6 text-white/60 md:text-[14.5px] group-open:hidden">{track.desc}</p>
            </div>
            <span
              class="track-chevron flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/15 bg-white/[0.04] text-white/80 transition-transform duration-300 md:h-10 md:w-10"
              aria-hidden="true"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9l6 6 6-6"></path>
              </svg>
            </span>
          </summary>

          <div class="px-5 pb-6 md:px-7 md:pb-8">
            <p class="text-sm leading-7 text-white/75 md:text-[15px]">{track.desc}</p>

            <div class="mt-6 rounded-2xl border border-white/10 bg-black/30 p-5 md:p-6">
              <div class="mb-4 text-[11px] font-semibold uppercase tracking-[0.2em] text-[color:var(--color-red-primary)]">
                {t.tracks.legend.examples}
              </div>
              <ul class="grid grid-cols-1 gap-x-8 gap-y-3 md:grid-cols-2">
                {track.examples.map((ex) => (
                  <li class="flex items-start gap-2.5 text-sm text-white/85 md:text-[15px]">
                    <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--color-red-primary)]"></span>
                    <span>{ex}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="mt-6 grid grid-cols-1 gap-0 overflow-hidden rounded-2xl border border-white/10 bg-white/[0.02] md:grid-cols-3 md:divide-x md:divide-white/10 rtl:md:divide-x-reverse">
              <div class="border-b border-white/10 p-5 md:border-b-0 md:p-6">
                <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-white/55">{t.tracks.legend.types}</div>
                <div class="mt-2 text-[13.5px] font-medium leading-7 text-white/90 md:text-sm">{track.types}</div>
              </div>
              <div class="border-b border-white/10 p-5 md:border-b-0 md:p-6">
                <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-white/55">{t.tracks.legend.who}</div>
                <div class="mt-2 text-[13.5px] font-medium leading-7 text-white/90 md:text-sm">{track.who}</div>
              </div>
              <div class="p-5 md:p-6">
                <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-white/55">{t.tracks.legend.deliverables}</div>
                <div class="mt-2 text-[13.5px] font-medium leading-7 text-white/90 md:text-sm">{track.deliverables}</div>
              </div>
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  details[open] > summary .track-chevron {
    transform: rotate(180deg);
  }
</style>
