---
import type { Content, Locale } from '../i18n/content';
interface Props { t: Content; locale: Locale }
const { t, locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${locale}/`;
const sectionHref = (h: string) => (h.startsWith('#') ? `${homeHref}${h}` : h);
---
<header
  data-site-header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-[color:var(--color-black-primary)]/85 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-[1240px] items-center gap-5 px-5 py-4 sm:px-8">
    <!-- Brand -->
    <a href={homeHref} class="flex shrink-0 items-center gap-3">
      <img src={`${base}/seulogo.svg`} alt="SEU" class="h-8 w-8" />
      <span class="whitespace-nowrap text-sm font-semibold tracking-wide text-white/90">{t.nav.brand}</span>
    </a>

    <!-- Section nav -->
    <nav class="mx-auto hidden items-center gap-6 text-[13.5px] text-white/80 lg:flex">
      {t.nav.sections.map((item) => (
        <a href={sectionHref(item.href)} class="transition hover:text-white">{item.label}</a>
      ))}
    </nav>

    <!-- Right cluster: lang switch + apply now + mobile menu -->
    <div class="ms-auto flex shrink-0 items-center gap-2.5">
      <a
        href={t.nav.langSwitchHref}
        class="rounded-full border border-white/15 px-3 py-1.5 text-xs font-medium text-white/85 transition hover:border-white/40 hover:text-white"
      >
        {t.nav.langSwitch}
      </a>
      <a
        href={`${base}/${locale}/register/`}
        class="inline-flex items-center rounded-full bg-[color:var(--color-red-primary)] px-4 py-2 text-[12.5px] font-semibold text-white shadow-[0_10px_30px_-10px_rgba(223,51,38,0.7)] transition hover:bg-[color:var(--color-red-primary-hover)]"
      >
        {t.nav.register.label}
      </a>
      <button
        type="button"
        class="inline-flex items-center rounded-md p-2 text-white/80 lg:hidden"
        aria-label="menu"
        data-mobile-nav-btn
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    class="hidden border-t border-white/5 bg-[color:var(--color-black-primary)] px-5 py-4 sm:px-8 lg:hidden"
    data-mobile-nav
  >
    <div class="mx-auto flex max-w-[1240px] flex-col gap-1.5 text-sm">
      {t.nav.sections.map((item) => (
        <a
          href={sectionHref(item.href)}
          class="rounded-md px-3 py-2 text-white/85 transition hover:bg-white/5 hover:text-white"
        >
          {item.label}
        </a>
      ))}
      <a
        href={`${base}/${locale}/register/`}
        class="mt-2 flex items-center justify-center gap-2 rounded-full bg-[color:var(--color-red-primary)] px-4 py-2.5 text-[13px] font-semibold text-white transition hover:bg-[color:var(--color-red-primary-hover)]"
      >
        {t.nav.register.label}
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.querySelector('[data-mobile-nav-btn]');
  const panel = document.querySelector('[data-mobile-nav]');
  btn?.addEventListener('click', () => {
    panel?.classList.toggle('hidden');
  });

  // Close mobile nav on any link click (anchor or full URL with hash)
  panel?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => panel?.classList.add('hidden'));
  });
</script>
