---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
const prizes = t.prizes;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section id="prizes" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="mb-12 text-center md:mb-14">
      <h2 class="text-3xl font-bold text-white md:text-4xl">{prizes.title}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-[15px] text-white/70">{prizes.lead}</p>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-3 md:gap-6 md:items-stretch">
      {prizes.items.map((item, i) => (
        <article
          class={`prize-card relative flex flex-col overflow-hidden rounded-3xl border p-7 transition md:p-8 ${
            item.highlight
              ? 'border-[color:var(--color-red-primary)]/50 bg-gradient-to-b from-[color:var(--color-red-primary)]/20 via-[color:var(--color-red-primary)]/8 to-white/[0.03] shadow-[0_24px_60px_-30px_rgba(223,51,38,0.55)] md:-translate-y-2'
              : 'border-white/10 bg-white/[0.03] hover:border-white/20 hover:bg-white/[0.05]'
          }`}
        >
          <div class="flex items-center justify-between gap-3">
            <div class="flex items-center gap-3">
              <span
                class={`inline-flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold ${
                  item.highlight
                    ? 'bg-[color:var(--color-red-primary)] text-white'
                    : 'bg-white/10 text-white/85'
                }`}
              >
                {i + 1}
              </span>
              <span class="text-[13px] font-semibold uppercase tracking-[0.18em] text-white/65">{item.rank}</span>
            </div>
            {item.highlight && (
              <svg viewBox="0 0 24 24" class="h-5 w-5 text-[color:var(--color-red-primary)]" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 21h8 M12 17v4 M7 4h10v5a5 5 0 0 1-10 0V4z M17 5h3v2a3 3 0 0 1-3 3 M7 5H4v2a3 3 0 0 0 3 3"></path>
              </svg>
            )}
          </div>

          <div class="mt-8 flex items-baseline gap-3 rtl:flex-row-reverse">
            <img
              src={`${base}/images/sar.svg`}
              alt={prizes.currency}
              class="h-9 w-auto md:h-11"
              style="filter: brightness(0) invert(1);"
            />
            <span class="text-5xl font-bold tabular-nums leading-none text-white md:text-6xl">{item.amount}</span>
          </div>

          {item.highlight && (
            <div class="pointer-events-none absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-transparent via-[color:var(--color-red-primary)] to-transparent"></div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
