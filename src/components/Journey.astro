---
import type { Content } from '../i18n/content';
interface Props { t: Content }
const { t } = Astro.props;
---
<section id="journey" class="relative border-y border-white/5 bg-white/[0.02] py-20 md:py-28">
  <div class="mx-auto max-w-[1240px] px-5 sm:px-8">
    <div class="mb-12 text-center md:mb-16">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">{t.journey.title}</h2>
      <p class="mt-3 text-[15px] text-white/60">{t.journey.subtitle}</p>
    </div>

    <div class="relative">
      <div class="pointer-events-none absolute top-[56px] start-0 end-0 hidden h-px bg-gradient-to-r from-transparent via-[color:var(--color-red-primary)]/40 to-transparent lg:block"></div>

      <ol class="grid gap-5 sm:grid-cols-2 md:grid-cols-4 lg:grid-cols-7">
        {t.journey.steps.map((step) => {
          const onsite = step.mode === 'onsite';
          const cardCls = onsite
            ? 'border-amber-300/30 bg-gradient-to-b from-amber-300/10 via-amber-300/5 to-transparent shadow-[0_24px_60px_-32px_rgba(252,211,77,0.5)]'
            : 'border-white/10 bg-white/[0.03]';
          const dayBadgeCls = onsite
            ? 'bg-amber-300 text-amber-950 shadow-[0_10px_30px_-10px_rgba(252,211,77,0.7)]'
            : 'bg-white/[0.05] text-white/90 border border-white/10';
          const dateCls = onsite ? 'text-amber-200' : 'text-[color:var(--color-red-primary)]';
          return (
            <li class={`relative flex flex-col rounded-2xl border p-4 md:p-5 ${cardCls}`}>
              <div class={`relative mx-auto flex h-14 w-14 items-center justify-center rounded-2xl text-xl font-extrabold ${dayBadgeCls}`}>
                {step.day}
              </div>
              <div class={`mt-3 text-center text-[11px] font-semibold uppercase tracking-[0.18em] ${dateCls}`}>
                {step.date}
              </div>
              <h3 class="mt-1.5 text-center text-[15px] font-bold text-white md:text-base">{step.title}</h3>
              <p class="mt-2 text-center text-[12.5px] leading-6 text-white/65 md:text-[13px]">
                {step.desc}
              </p>

              <div class="mt-3 flex flex-wrap items-center justify-center gap-1.5">
                {onsite ? (
                  <div class="inline-flex items-center gap-1.5 rounded-full border border-amber-300/45 bg-amber-300/12 px-2.5 py-0.5 text-[10.5px] font-semibold text-amber-100">
                    <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s-7-7.58-7-13a7 7 0 1114 0c0 5.42-7 13-7 13z M12 11a2 2 0 100-4 2 2 0 000 4z"></path>
                    </svg>
                    {t.journey.onsiteLabel}
                  </div>
                ) : (
                  <div class="inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-white/[0.04] px-2.5 py-0.5 text-[10.5px] font-medium text-white/70">
                    <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M17.5 19a4.5 4.5 0 100-9h-1.26A8 8 0 104 16.25"></path>
                    </svg>
                    {t.journey.virtualLabel}
                  </div>
                )}
              </div>

              {step.finalists && (
                <div class="mt-3 rounded-lg border border-[color:var(--color-red-primary)]/35 bg-[color:var(--color-red-primary)]/10 px-2.5 py-1.5 text-center text-[10.5px] font-semibold leading-4 text-white">
                  {t.journey.finalistsCalloutLabel}
                </div>
              )}
            </li>
          );
        })}
      </ol>
    </div>
  </div>
</section>
